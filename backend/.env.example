# Server Configuration
PORT=5001
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/civicpulse?retryWrites=true&w=majority

# Security
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
ADMIN_SECRET_CODE=123456

# CORS (comma separated list of allowed origins)
ALLOWED_ORIGINS=https://your-production-app.com,https://www.your-production-app.com
